# Copier en .env.local pour tester la synchro des avis Google en local (jamais commité).
# En production, ces variables se règlent dans Netlify → Site settings → Environment variables.

GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# URL du "Build hook" Netlify utilisé par netlify/functions/refresh-reviews.mjs
# pour redéclencher un build chaque semaine (Netlify → Site settings → Build & deploy → Build hooks).
NETLIFY_BUILD_HOOK_URL=
