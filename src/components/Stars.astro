---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<span class={`stars ${className}`} role="img" aria-label="Note de 5 étoiles sur 5">
  {
    Array.from({ length: 5 }).map(() => (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2.5l2.95 5.98 6.6.96-4.77 4.65 1.12 6.57L12 17.56l-5.9 3.1 1.12-6.57L2.45 9.44l6.6-.96L12 2.5z" />
      </svg>
    ))
  }
</span>

<style>
  .stars {
    display: inline-flex;
    gap: 3px;
    color: #d9a441;
  }
</style>
