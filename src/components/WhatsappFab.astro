---
import { SITE } from '../data/site';

// Numéro au format international sans espaces ni « + » pour wa.me.
const waNumber = SITE.phone.replace(/[^0-9]/g, '');
const message = encodeURIComponent(
  'Bonjour Docteur, je souhaite prendre un rendez-vous.'
);
const href = `https://wa.me/${waNumber}?text=${message}`;
---

<a
  class="wa-fab"
  href={href}
  target="_blank"
  rel="noopener"
  aria-label="Prendre rendez-vous sur WhatsApp"
>
  <svg class="wa-fab-icon" width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91C21.96 6.45 17.5 2 12.04 2zm0 18.15h-.01a8.2 8.2 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.22 8.22 0 0 1-1.26-4.35c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.19 8.19 0 0 1 2.41 5.83c0 4.54-3.7 8.24-8.24 8.24zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43-.14-.01-.31-.01-.48-.01-.17 0-.43.06-.66.31-.23.25-.87.85-.87 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.24 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z" />
  </svg>
  <span class="wa-fab-label">Prendre RDV sur WhatsApp</span>
</a>

<style>
  .wa-fab {
    position: fixed;
    right: clamp(1rem, 3vw, 1.75rem);
    bottom: clamp(1rem, 3vw, 1.75rem);
    z-index: 200;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.1rem 0.7rem 0.85rem;
    border-radius: 999px;
    background: #25d366;
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
    line-height: 1;
    box-shadow: 0 6px 22px rgba(37, 211, 102, 0.4);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .wa-fab:hover {
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(37, 211, 102, 0.5);
  }

  .wa-fab-icon {
    flex-shrink: 0;
  }

  /* Sur petits écrans : bouton rond (icône seule) pour ne pas gêner. */
  @media (max-width: 620px) {
    .wa-fab {
      padding: 0.8rem;
    }

    .wa-fab-label {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-fab:hover {
      transform: none;
    }
  }
</style>
