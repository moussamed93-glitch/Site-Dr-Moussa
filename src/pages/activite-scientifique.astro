---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaRdv from '../components/CtaRdv.astro';
import { resolveImage } from '../lib/images';
import commData from '../data/communications.json';
import page from '../data/pages/activite-scientifique.json';

const heroImg = resolveImage(page.hero.image);

// Textes ET photos sont éditables dans le backoffice ; chaque photo est référencée
// par une URL résolue à partir du nom de fichier choisi dans le CMS.
const communications = commData.communications.map((c) => ({
  src: resolveImage(c.image),
  alt: `Le Dr Moussa — ${c.congress}`,
  congress: c.congress,
  subject: c.subject,
  year: c.year,
}));
---

<Base
  title="Activité scientifique et congrès | Dr Mohamed Moussa"
  description="Congrès nationaux et internationaux, communications scientifiques, formation continue : l'engagement scientifique du Dr Moussa, ophtalmologue à Ariana."
  breadcrumbs={[
    { name: 'Accueil', href: '/' },
    { name: 'Activité scientifique', href: '/activite-scientifique/' },
  ]}
>
  <PageHero
    image={heroImg}
    imageAlt={page.hero.imageAlt}
    focus="30% 40%"
    eyebrow={page.hero.eyebrow}
    title={page.hero.title}
    lead={page.hero.lead}
    crumbs={[
      { name: 'Accueil', href: '/' },
      { name: 'Activité scientifique', href: '/activite-scientifique/' },
    ]}
  />

  <section class="section">
    <div class="container">
      <dl class="pillars reveal">
        {
          page.pillars.map((p) => (
            <div class="pillar">
              <dt><span>{p.num}</span> {p.title}</dt>
              <dd>{p.text}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <section class="section comms">
    <div class="container">
      <div class="comms-head reveal">
        <p class="eyebrow">{page.commsEyebrow}</p>
        <h2>{page.commsTitle}</h2>
      </div>
      <div class="comms-grid">
        {
          communications.map((c, i) => (
            <figure class="comm reveal" style={`animation-delay:${i * 70}ms`}>
              <Image src={c.src} alt={c.alt} widths={[400, 640]} sizes="(min-width: 900px) 30vw, (min-width: 600px) 46vw, 94vw" loading="lazy" decoding="async" />
              <figcaption>
                <span class="comm-year">{c.year}</span>
                <p class="comm-congress">{c.congress}</p>
                <p class="comm-subject">{c.subject}</p>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <CtaRdv />
</Base>

<style>
  .pillars {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin: 0;
  }

  @media (min-width: 820px) {
    .pillars {
      grid-template-columns: repeat(3, 1fr);
    }

    .pillar + .pillar {
      border-left: 1px solid var(--line);
      padding-left: clamp(1.5rem, 4vw, 3rem);
    }
  }

  .pillar dt {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--navy-800);
    margin-bottom: var(--s-3);
  }

  .pillar dt span {
    display: block;
    font-size: var(--text-sm);
    color: var(--taupe-500);
    margin-bottom: var(--s-2);
  }

  .pillar dd {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--ink-soft);
    max-width: 40ch;
  }

  .comms {
    background: var(--surface);
    border-block: 1px solid var(--line);
  }

  .comms-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .comms-grid {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem) var(--s-5);
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .comm {
    margin: 0;
  }

  .comm img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    display: block;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .comm figcaption {
    padding-top: var(--s-4);
    border-top: 1px solid var(--taupe-300);
    margin-top: var(--s-4);
  }

  .comm-year {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--taupe-600);
  }

  .comm-congress {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--navy-800);
    margin-top: var(--s-1);
  }

  .comm-subject {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin-top: var(--s-1);
  }
</style>
