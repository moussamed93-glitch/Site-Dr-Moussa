---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaRdv from '../components/CtaRdv.astro';
import { resolveImage } from '../lib/images';
import accueilLogo from '../assets/images/accueil-logo.jpg';
import pageData from '../data/pages/cabinet.json';

type GalleryItem = { src: ImageMetadata; alt: string; caption: string };

const gallery: GalleryItem[] = pageData.gallery
  .map((item) => ({ src: resolveImage(item.image), alt: item.alt, caption: item.caption }))
  .filter((item): item is GalleryItem => Boolean(item.src));
---

<Base
  title="Le cabinet — visite en images | Dr Mohamed Moussa, Ariana"
  description="Le cabinet d'ophtalmologie du Dr Moussa au Centre Médical Horizon, Cité Intilaka (Mnihla), Ariana : accueil, salle d'attente, consultation."
  breadcrumbs={[
    { name: 'Accueil', href: '/' },
    { name: 'Le cabinet', href: '/cabinet/' },
  ]}
>
  <PageHero
    image={resolveImage(pageData.hero.image) ?? accueilLogo}
    focus="center 40%"
    eyebrow={pageData.hero.eyebrow}
    title={pageData.hero.title}
    lead={pageData.hero.lead}
    crumbs={[
      { name: 'Accueil', href: '/' },
      { name: 'Le cabinet', href: '/cabinet/' },
    ]}
  />

  <section class="section">
    <div class="container">
      <div class="gallery">
        {
          gallery.map((item, i) => (
            <figure class="gallery-item reveal" style={`animation-delay:${(i % 3) * 60}ms`}>
              <Image
                src={item.src}
                alt={item.alt}
                widths={[480, 800, 1200]}
                sizes="(max-width: 720px) 100vw, (max-width: 1080px) 50vw, 33vw"
                loading={i < 3 ? 'eager' : 'lazy'}
              />
              <figcaption>{item.caption}</figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <CtaRdv />
</Base>

<style>
  .gallery {
    columns: 1;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  @media (min-width: 640px) {
    .gallery {
      columns: 2;
    }
  }

  @media (min-width: 1024px) {
    .gallery {
      columns: 3;
    }
  }

  .gallery-item {
    margin: 0 0 clamp(1.5rem, 3vw, 2.5rem);
    break-inside: avoid;
  }

  .gallery-item img {
    width: 100%;
    display: block;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .gallery-item figcaption {
    padding-top: var(--s-3);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--taupe-600);
    border-top: 1px solid var(--taupe-300);
    margin-top: var(--s-3);
  }
</style>
