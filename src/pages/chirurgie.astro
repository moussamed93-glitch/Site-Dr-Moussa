---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaRdv from '../components/CtaRdv.astro';
import { resolveImage } from '../lib/images';
import { renderInline } from '../lib/richtext';
import pageData from '../data/pages/chirurgie.json';

const blocPhotos = pageData.blocPhotos.map((photo) => ({
  src: resolveImage(photo.image),
  alt: photo.alt,
}));
---

<Base
  title="Chirurgie de la cataracte et réfractive à Ariana | Dr Moussa"
  description="Chirurgie de la cataracte et chirurgie réfractive par le Dr Mohamed Moussa, avec suivi complet au cabinet à Mnihla, Ariana. Bilan pré-opératoire sur place."
  breadcrumbs={[
    { name: 'Accueil', href: '/' },
    { name: 'Chirurgie', href: '/chirurgie/' },
  ]}
>
  <PageHero
    image={resolveImage(pageData.hero.image)}
    imageAlt={pageData.hero.imageAlt}
    focus="center 30%"
    eyebrow={pageData.hero.eyebrow}
    title={pageData.hero.title}
    lead={pageData.hero.lead}
    crumbs={[
      { name: 'Accueil', href: '/' },
      { name: 'Chirurgie', href: '/chirurgie/' },
    ]}
  />

  <section class="section">
    <div class="container surgery-cols">
      {
        pageData.surgery.map((col) => (
          <article class="surgery-col reveal">
            <span class="surgery-num">{col.num}</span>
            <h2>{col.title}</h2>
            <p set:html={renderInline(col.text1)} />
            <p set:html={renderInline(col.text2)} />
            <a href={col.link} class="line-link">{col.linkLabel}</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section bloc">
    <div class="container">
      <div class="bloc-head reveal">
        <p class="eyebrow">{pageData.blocEyebrow}</p>
        <h2>{pageData.blocTitle}</h2>
      </div>
      <div class="bloc-grid">
        {
          blocPhotos.map((photo, i) => (
            <figure class="bloc-figure reveal" style={`animation-delay:${i * 70}ms`}>
              <Image src={photo.src} alt={photo.alt} widths={[400, 640]} sizes="(min-width: 900px) 32vw, (min-width: 600px) 46vw, 94vw" loading="lazy" decoding="async" />
            </figure>
          ))
        }
      </div>
      <p class="bloc-note reveal">{pageData.blocNote}</p>
    </div>
  </section>

  <CtaRdv
    title="Un projet chirurgical ? Parlons-en."
    text="Chaque décision opératoire commence par une consultation approfondie : bilan complet, explication des options et réponse à toutes vos questions."
  />
</Base>

<style>
  .surgery-cols {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
  }

  @media (min-width: 820px) {
    .surgery-cols {
      grid-template-columns: 1fr 1fr;
    }

    .surgery-col + .surgery-col {
      border-left: 1px solid var(--line);
      padding-left: clamp(2rem, 5vw, 4rem);
    }
  }

  .surgery-num {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--taupe-500);
  }

  .surgery-col h2 {
    margin-block: var(--s-3) var(--s-4);
  }

  .surgery-col p + p {
    margin-top: var(--s-4);
  }

  .surgery-col p {
    color: var(--ink-soft);
  }

  .line-link {
    display: inline-block;
    margin-top: var(--s-5);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--navy-800);
    border-bottom: 1px solid var(--taupe-500);
    padding-bottom: 4px;
    transition: border-color var(--transition), color var(--transition);
  }

  .line-link:hover {
    color: var(--blue-logo);
    border-color: var(--blue-logo);
  }

  .bloc {
    background: var(--surface);
    border-block: 1px solid var(--line);
  }

  .bloc-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .bloc-grid {
    display: grid;
    gap: var(--s-3);
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .bloc-figure {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .bloc-figure img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    display: block;
  }

  .bloc-note {
    margin-top: var(--s-4);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--ink-mute);
  }
</style>
