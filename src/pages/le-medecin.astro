---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaRdv from '../components/CtaRdv.astro';
import { SITE } from '../data/site';
import { resolveImage } from '../lib/images';
import page from '../data/pages/le-medecin.json';
import fallbackImg from '../assets/images/medecin-cabinet.jpg';

const heroImg = resolveImage(page.hero.image) ?? fallbackImg;
const portraitImg = resolveImage(page.bio.image) ?? fallbackImg;
const examenImg = resolveImage(page.science.image) ?? fallbackImg;

const physicianLd = {
  '@context': 'https://schema.org',
  '@type': 'Physician',
  '@id': `${SITE.url}/le-medecin/#physician`,
  name: SITE.doctor,
  medicalSpecialty: 'Ophthalmologic',
  description:
    "Médecin ophtalmologiste à Cité Intilaka (Mnihla), Ariana. Diplômé de la Faculté de Médecine de Tunis. Consultation et chirurgie oculaire, adultes et enfants.",
  telephone: SITE.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: `${SITE.address.line1}, ${SITE.address.line2}`,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.region,
    postalCode: SITE.address.postalCode,
    addressCountry: 'TN',
  },
  alumniOf: 'Faculté de Médecine de Tunis',
};
---

<Base
  title="Le médecin — Dr Mohamed Moussa, ophtalmologue à Ariana"
  description="Dr Mohamed Moussa, diplômé de la Faculté de Médecine de Tunis, ophtalmologiste à Mnihla, Ariana. Parcours, valeurs et engagement scientifique."
  jsonLd={[physicianLd]}
  breadcrumbs={[
    { name: 'Accueil', href: '/' },
    { name: 'Le médecin', href: '/le-medecin/' },
  ]}
>
  <PageHero
    image={heroImg}
    focus="68% 28%"
    eyebrow={page.hero.eyebrow}
    title={page.hero.title}
    lead={page.hero.lead}
    crumbs={[
      { name: 'Accueil', href: '/' },
      { name: 'Le médecin', href: '/le-medecin/' },
    ]}
  />

  <section class="section">
    <div class="container bio-grid">
      <figure class="bio-media reveal">
        <Image
          src={portraitImg}
          alt={page.bio.imageAlt}
          widths={[480, 700, 1000]}
          sizes="(max-width: 768px) 100vw, 40vw"
        />
      </figure>
      <div class="bio-text reveal">
        <p class="eyebrow">{page.bio.eyebrow}</p>
        <h2>{page.bio.title}</h2>
        <p>{page.bio.text1}</p>
        <p>{page.bio.text2}</p>
        <dl class="bio-facts">
          {
            page.bio.facts.map((f) => (
              <div>
                <dt>{f.label}</dt>
                <dd>{f.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <section class="section science">
    <div class="container science-grid">
      <div class="science-text reveal">
        <p class="eyebrow">{page.science.eyebrow}</p>
        <h2>{page.science.title}</h2>
        <p>{page.science.text1}</p>
        <p>{page.science.text2}</p>
        <a href="/activite-scientifique/" class="line-link">Voir l'activité scientifique</a>
      </div>
      <figure class="science-media reveal">
        <Image
          src={examenImg}
          alt={page.science.imageAlt}
          widths={[480, 700, 1000]}
          sizes="(max-width: 768px) 100vw, 42vw"
        />
      </figure>
    </div>
  </section>

  <CtaRdv />
</Base>

<style>
  .bio-grid,
  .science-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  @media (min-width: 860px) {
    .bio-grid {
      grid-template-columns: 0.85fr 1.15fr;
    }
    .science-grid {
      grid-template-columns: 1.15fr 0.85fr;
    }
  }

  .bio-media,
  .science-media {
    margin: 0;
    position: relative;
  }

  .bio-media::before,
  .science-media::before {
    content: '';
    position: absolute;
    inset: 10% -6% -6% 12%;
    background: var(--sand-200);
    border-radius: var(--radius-lg);
  }

  .bio-media img,
  .science-media img {
    position: relative;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  .bio-text h2,
  .science-text h2 {
    margin-bottom: var(--s-5);
  }

  .bio-text p + p,
  .science-text p + p {
    margin-top: var(--s-4);
  }

  .bio-facts {
    margin: var(--s-6) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0 var(--s-6);
  }

  .bio-facts div {
    padding-block: var(--s-4);
    border-top: 1px solid var(--line);
  }

  .bio-facts dt {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--taupe-600);
    margin-bottom: var(--s-1);
  }

  .bio-facts dd {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .science {
    background: var(--surface);
    border-block: 1px solid var(--line);
  }

  .line-link {
    display: inline-block;
    margin-top: var(--s-5);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--navy-800);
    border-bottom: 1px solid var(--taupe-500);
    padding-bottom: 4px;
    transition: border-color var(--transition), color var(--transition);
  }

  .line-link:hover {
    color: var(--blue-logo);
    border-color: var(--blue-logo);
  }

  @media (max-width: 859px) {
    .science-media {
      order: -1;
    }
  }
</style>
