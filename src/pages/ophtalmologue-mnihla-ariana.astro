---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaRdv from '../components/CtaRdv.astro';
import { SITE } from '../data/site';
import { resolveImage } from '../lib/images';
import { renderInline } from '../lib/richtext';
import page from '../data/pages/ophtalmologue-mnihla.json';
import fallbackImg from '../assets/images/accueil-logo.jpg';

const heroImg = resolveImage(page.hero.image) ?? fallbackImg;
const zones = page.zones;
---

<Base
  title="Ophtalmologue à Cité Intilaka (Mnihla), Ariana | Dr Moussa"
  description="Ophtalmologue à Mnihla, Cité Intilaka, Ettadhamen, Ariana : le cabinet du Dr Moussa vous accueille au Centre Médical Horizon, Route de Bizerte Km 4."
  breadcrumbs={[
    { name: 'Accueil', href: '/' },
    { name: 'Ophtalmologue à Mnihla, Ariana', href: '/ophtalmologue-mnihla-ariana/' },
  ]}
>
  <PageHero
    image={heroImg}
    focus="center 40%"
    compact
    eyebrow={page.hero.eyebrow}
    title={page.hero.title}
    lead={page.hero.lead}
    crumbs={[
      { name: 'Accueil', href: '/' },
      { name: 'Ophtalmologue à Mnihla, Ariana', href: '/ophtalmologue-mnihla-ariana/' },
    ]}
  />

  <section class="section">
    <div class="container container--narrow">
      <div class="prose reveal">
        <h2>{page.locationTitle}</h2>
        <p>{page.locationText}</p>

        <h2>{page.zonesTitle}</h2>
        <p>{page.zonesText}</p>
        <ul class="zones-list">
          {zones.map((z) => <li>{z}</li>)}
        </ul>

        <h2>{page.comingTitle}</h2>
        <p set:html={renderInline(page.comingText1)} />
        <p set:html={renderInline(page.comingText2)} />

        <h2>{page.coordsTitle}</h2>
        <p>
          {SITE.name}<br />
          {SITE.address.line1}<br />
          {SITE.address.line2}, {SITE.address.city}<br />
          {SITE.address.region} {SITE.address.postalCode}, {SITE.address.country}<br />
          Téléphone : <a href={`tel:${SITE.phone.replace(/\s/g, '')}`}>{SITE.phoneDisplay}</a><br />
          E-mail : <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </p>
        <p>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener" class="btn btn--primary">
            Itinéraire Google Maps
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class="map-section" aria-label="Plan d'accès">
    <iframe
      src={SITE.mapsEmbed}
      width="100%"
      height="420"
      style="border:0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Plan d'accès au cabinet d'ophtalmologie — Cité Intilaka (Mnihla), Ariana"
    ></iframe>
  </section>

  <CtaRdv />
</Base>

<style>
  .prose h2 {
    margin-top: var(--s-6);
    margin-bottom: var(--s-3);
  }

  .prose p {
    margin-bottom: var(--s-4);
  }

  .zones-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    list-style: none;
    padding: 0;
    margin: 0 0 var(--s-4);
  }

  .zones-list li {
    padding: 0.4rem 1rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: var(--text-sm);
    color: var(--navy-700);
  }

  .map-section {
    border-block: 1px solid var(--line);
  }

  .map-section iframe {
    display: block;
    filter: grayscale(0.2);
  }
</style>
