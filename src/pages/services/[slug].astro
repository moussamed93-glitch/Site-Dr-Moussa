---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import CtaRdv from '../../components/CtaRdv.astro';
import { resolveImage } from '../../lib/images';
import fallbackImg from '../../assets/images/materiel-vue.jpg';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.id.replace(/\.md$/, '') },
    props: { service },
  }));
}

const { service } = Astro.props;
const { data } = service;
const { Content } = await render(service);
const slug = service.id.replace(/\.md$/, '');
const heroImg = resolveImage(data.image) ?? fallbackImg;

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: data.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title={data.metaTitle}
  description={data.metaDescription}
  jsonLd={[faqLd]}
  breadcrumbs={[
    { name: 'Accueil', href: '/' },
    { name: 'Services', href: '/services/' },
    { name: data.title, href: `/services/${slug}/` },
  ]}
>
  <PageHero
    image={heroImg}
    focus="center 45%"
    compact
    eyebrow="Nos services"
    title={data.title}
    lead={data.intro}
    crumbs={[
      { name: 'Accueil', href: '/' },
      { name: 'Services', href: '/services/' },
      { name: data.title, href: `/services/${slug}/` },
    ]}
  />

  <article class="section-slim">
    <div class="container container--narrow">
      <div class="prose reveal">
        <Content />
      </div>

      <div class="split-cols reveal">
        <section class="col-block">
          <h2>Symptômes</h2>
          <ul>
            {data.symptoms.map((s) => <li>{s}</li>)}
          </ul>
        </section>
        <section class="col-block">
          <h2>Quand consulter ?</h2>
          <ul>
            {data.whenToConsult.map((s) => <li>{s}</li>)}
          </ul>
        </section>
      </div>

      <section class="reveal">
        <h2 class="block-title">Traitement et prise en charge</h2>
        <div class="treatments">
          {
            data.treatments.map((t, i) => (
              <div class="treatment">
                <span class="treatment-index">{String(i + 1).padStart(2, '0')}</span>
                <div>
                  <h3>{t.title}</h3>
                  <p>{t.text}</p>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="reveal">
        <h2 class="block-title">Questions fréquentes</h2>
        <div class="faq">
          {
            data.faq.map((f) => (
              <details class="faq-item">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))
          }
        </div>
      </section>
    </div>
  </article>

  <CtaRdv
    title={`Prendre rendez-vous — ${data.title}`}
    text={`Pour toute question concernant ${data.title.toLowerCase()}, le cabinet du Dr Moussa vous accueille à Cité Intilaka (Mnihla), Ariana.`}
  />
</Base>

<style>
  .section-slim {
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }

  .prose :global(p) {
    margin-bottom: var(--s-4);
  }

  .split-cols {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-block: var(--s-6);
    border-top: 1px solid var(--line);
    padding-top: var(--s-6);
  }

  @media (min-width: 720px) {
    .split-cols {
      grid-template-columns: 1fr 1fr;
    }

    .col-block + .col-block {
      border-left: 1px solid var(--line);
      padding-left: clamp(1.5rem, 4vw, 3rem);
    }
  }

  .col-block h2 {
    font-size: var(--text-xs);
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--taupe-600);
    margin-bottom: var(--s-4);
  }

  .col-block ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
  }

  .col-block li {
    padding-block: var(--s-3);
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: var(--text-sm);
  }

  .col-block li:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .block-title {
    margin-block: var(--s-7) var(--s-5);
    padding-top: var(--s-6);
    border-top: 1px solid var(--line);
  }

  .treatments {
    display: grid;
    gap: var(--s-5);
  }

  .treatment {
    display: flex;
    gap: var(--s-4);
    align-items: flex-start;
  }

  .treatment-index {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--taupe-500);
    line-height: 1.2;
    min-width: 2.2rem;
  }

  .treatment h3 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--navy-800);
    margin-bottom: var(--s-1);
  }

  .treatment p {
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .faq {
    display: grid;
  }

  .faq-item {
    border-top: 1px solid var(--line);
  }

  .faq-item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .faq-item summary {
    padding: var(--s-4) 2.6rem var(--s-4) 0;
    font-weight: 500;
    cursor: pointer;
    list-style: none;
    position: relative;
    transition: color var(--transition);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: var(--s-2);
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.3rem;
    font-weight: 300;
    color: var(--taupe-600);
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item summary:hover {
    color: var(--blue-logo);
  }

  .faq-item p {
    padding: 0 0 var(--s-5);
    color: var(--ink-soft);
    font-size: var(--text-sm);
    max-width: 65ch;
  }
</style>
